# ============================================================
# Vibe 环境变量 — 部署时复制为 .env 并填入真实值
# ============================================================

# --- 数据库（阿里云 RDS MySQL） ---
DB_HOST=rm-bp1ocf8i1y44p9ghdxo.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=wuleimysql
DB_PASSWORD=change-me
DB_NAME=vibe_db

# --- 七牛云 ---
QINIU_ACCESS_KEY=change-me
QINIU_SECRET_KEY=change-me
QINIU_BUCKET=yhugo
QINIU_REGION=z1
QINIU_DOMAIN=https://static.yhugo.cn
QINIU_PREFIX=zywoo

# --- 认证 ---
ACCESS_CODE=change-me-to-a-strong-pin
JWT_SECRET=change-me-to-a-random-string

# --- CORS（逗号分隔，填 App/前端来源，如 https://api.example.com；iOS 原生不发 Origin 可留空）---
CORS_ORIGINS=

# --- 服务 ---
GIN_MODE=release
SERVER_PORT=8080

# --- AI 评价（可切换供应商：glm / deepseek） ---
AI_PROVIDER=deepseek
GLM_API_KEY=change-me
DEEPSEEK_API_KEY=change-me
